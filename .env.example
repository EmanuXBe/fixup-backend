# ===========================================================================
# FixUp API — Variables de Entorno (.env.example)
# ===========================================================================
# INSTRUCCIONES:
# 1. Copia este archivo como .env:  cp .env.example .env
# 2. Rellena los valores con tus credenciales locales
# 3. NUNCA subas el archivo .env a Git (ya está en .gitignore)
#
# En producción (Render), estas variables se configuran en:
# Dashboard → Tu Servicio → Environment → Environment Variables
# ===========================================================================

# ─── Entorno de ejecución ────────────────────────────────────────────────
# Valores: 'development' | 'production'
# Render establece 'production' automáticamente; NO necesitas configurarla
NODE_ENV=development

# ─── Conexión a PostgreSQL ───────────────────────────────────────────────
# Formato: postgres://usuario:contraseña@host:puerto/nombre_bd
# Para Render: copia la "External Database URL" desde el dashboard de PostgreSQL
DATABASE_URL=postgres://usuario:contraseña@localhost:5432/fixup_dev

# ─── Puerto del servidor ────────────────────────────────────────────────
# Render asigna el puerto automáticamente; NO necesitas configurarla en Render
# En local, usa 3000 o cualquier puerto libre
PORT=3000

# ─── CORS — URL del frontend (solo producción) ──────────────────────────
# URL completa del frontend desplegado que consumirá esta API
# Ejemplo: https://fixup-frontend.onrender.com
# FRONTEND_URL=https://tu-frontend.onrender.com
